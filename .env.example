PORT=3000

# SMTP Email Configuration (use Gmail App Password, SendGrid, Mailgun, etc.)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-app-password

# Where to receive inquiry / quote emails
MAIL_TO=azadenterprises@example.com
MAIL_FROM="Azad Enterprises Website <no-reply@azadenterprises.com>"
